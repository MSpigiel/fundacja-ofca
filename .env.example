# Vercel Blob Storage - required for image uploads
# Get this from: Vercel Dashboard → Storage → Create Blob Store
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxxxxxx

# Upstash Redis (Vercel KV) - required for article storage
# Get this from: Vercel Dashboard → Storage → Create Redis (Upstash)
KV_REST_API_URL=https://xxxxxxxxxxxx.upstash.io
KV_REST_API_TOKEN=AXxxxxxxxxxxxx
